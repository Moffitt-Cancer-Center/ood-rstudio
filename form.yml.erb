<%
  # ── Dynamic package list ────────────────────────────────────────────────────
  # Read data/packages.yml at form-render time so new user-contributed packages
  # (appended at job-submission time) are visible to all users immediately.
  require 'yaml'
  require 'pathname'
  begin
    _pkg_file = Pathname.new(__FILE__).dirname.join('data', 'packages.yml')
    _pkg_data = YAML.safe_load(_pkg_file.read) || {}
  rescue => _e
    _pkg_data = {}
  end
  _pkg_list    = (_pkg_data['packages'] || []).map { |p| [p['label'].to_s, p['value'].to_s] }
  _pkg_options = [["-- None --", ""]] + _pkg_list
%>
---
tile:
  title: "RStudio Server"
  border_color: "light green"
  sub_caption: "Empower Your Analysis"
cluster: "slurm"
description: |
  This app will launch RStudio server on one Red node. 

  **NOTE - If this is the first time you are starting this new Rstudio app, please allow for up to 5 minutes while the container builds. You can check the progress of the build in the 'output.log' file.**
attributes:
  bc_queue: "red"
  bc_account: null
  bc_num_hours:
    widget: "number_field"
    label: "Runtime [hours]"
    help: Number of hours to run
    value: 1
    min: 1
    max: 336
    step: 1
  bc_mem:
    widget: "select"
    label: "Maximum Memory (GB)"
    help: Memory to allocate for job
    value: "8G"
    options:
      - ["Reserve 1GB", "1G"]
      - ["Reserve 2GB", "2G"]
      - ["Reserve 4GB", "4G"]
      - ["Reserve 8GB", "8G"]
      - ["Reserve 16GB", "16G"]
      - ["Reserve 32GB", "32G"]
      - ["Reserve 64GB", "64G"]
      - ["Reserve 128GB", "128G"]
      - ["Reserve 256GB", "256G"]
      - ["Reserve 512GB", "512G"]
      - ["Reserve 768GB", "768G"]
      - ["Reserve 960GB", "960G"]
  bc_num_cores:
    widget: "number_field"
    label: "Number of CPU Cores"
    help: Number of cores to allocate
    value: 1
    min: 1
    max: 64
    step: 1
  bc_num_gpu:
    widget: "select"
    label: "GPU:count"
    options:
      - ["No GPU required", "0"]
      - ["Single(1) GPU", "1"]
    help: |
       - **none** or **A30:x (e.g. A30:1)**
  bc_num_slots: 1
  r_version:
    display: true
    widget: "select"
    label: "R/RStudio version"
    value: "ml"
    options:
      - ["Moffitt-ML", "ml"]
      - ["Moffitt-modified", "modified"]
      - ["Rocker-tidyverse", "tidyverse"]
        # - ["Rocker-shiny-verse", "shiny-verse"]
      - ["Rocker-r-ver", "r-ver"]
      - ["Rocker-r-base", "r-base"]
      - ["Rocker-geospatial", "geospatial"]
        # - ["Rocker-shiny", "shiny"]
      - ["Rocker-rstudio-stable", "rstudio-stable"]
      - ["Rocker-verse", "verse"]
      - ["Rocker-binder", "binder"]
      - ["Rocker-cuda", "cuda"]
      - ["Rocker-r2u", "r2u"]
      - ["Rocker-ml-verse", "ml-verse"]
      - ["Rocker-ropensci", "ropensci"]
      - ["Rocker-ml", "ml-gpu"]
        # - ["dontuse", "dontuse"]
    help: |
      - **Rocker-ml** - Latest Rocker RStudio ML container
      - **Moffitt-ml** - Moffitt-ized Rocker RStudio ML container
      - **Moffitt-modified** - **Moffitt-ml** with some additional packages built into the image
  qos:
    label: "QoS (Quality of Service level)"
    widget: "select"
    value: "normal"
    options:
      - ["Normal (64 cpus, 12hrs)", "normal"]
      - ["PartSmall (250 cpus, 90 days)", "partsmall"]
      - ["Small (475 cpus, 90 days)", "small"]
      - ["Medium (950 cpus, 45 days)", "medium"]
      - ["Large (1425 cpus, 1 day)", "large"]
      - ["X-Large (1800 cpus, 4 hrs)", "xlarge"]
      - ["XX-Large (3000 cpus, 12 hrs)", "xxlarge"]

  custom_packages:
    widget: "select"
    multiple: true
    label: "Common Ubuntu Packages"
    help: |
      Select one or more Ubuntu packages to install in your custom container.
      Hold **Ctrl** (Windows/Linux) or **Cmd** (macOS) to select multiple packages.
      A custom Apptainer image will be built on first use and **cached** for subsequent sessions —
      it will only rebuild when your package selection changes.
      **New packages you type in the field below are added to this list for all users.**
      The Apptainer definition file is saved to `~/.local/share/rstudio/custom-build/rstudio-custom.def`
      so you can inspect or hand-edit it between sessions.
    options:
<% _pkg_options.each do |_lbl, _val| -%>
      - [<%= _lbl.inspect %>, <%= _val.inspect %>]
<% end -%>

  extra_packages:
    widget: "text_field"
    label: "Additional Ubuntu Packages"
    value: ""
    help: |
      Type any extra Ubuntu package names separated by **spaces or commas**
      (e.g. `libgeos-dev, libbz2-dev`).
      Only valid Debian/Ubuntu package-name characters are accepted (letters, digits, `-`, `.`, `+`).
      **Packages typed here are automatically added to the list above** so all users can find
      them in future sessions. Leave blank if you have no additional packages beyond those selected above.

  bypass_custom_build:
    widget: "check_box"
    label: "Bypass custom container build"
    value: "0"
    help: |
      Check this box to **skip** building a custom container and launch with the plain base
      R/RStudio image instead.  Use this to recover if a previous custom build fails or
      causes launch issues.

form:
  - r_version
  - bc_account
  - bc_queue
  - bc_num_hours
  - bc_num_cores
  - bc_mem
  - bc_num_gpu
  - bc_num_slots
  - qos
  - custom_packages
  - extra_packages
  - bypass_custom_build
  # - bc_email_on_started
