#!/usr/bin/env bash

# This script start up rstudio server from a container. It originates
# from a template script with minimal ood processing parameters.
# 
# The script is a mixture of a locally (MCC) developed script and
# https://github.com/OSC/bc_osc_rstudio_server/blob/master/template/script.sh.erb
# and
# https://github.com/UCL-ARC/ood-rstudio-app/blob/main/template/script.sh.erb
#
# High-level overview:
#  - setup environment variables
#  - setup paths (permanent and temporary) for system logs, configs, etc
#  - execute (in container) rstudio server

##################################################################
#-
#- Function definitions
#-
##################################################################
create_log_config() {
   LOG_CF=$1
   if [ ! -f "$LOG_CF" ]; then
      printf "[*]\nlogger-type=file\nlog-dir=/var/log/rstudio\n" > ${LOG_CF}
      printf "log-level=info\n" >> ${LOG_CF}
   fi
}
create_db_config() {
   DB_CF=$1
   if [ ! -f "$DB_CF" ]; then
      printf "provider=sqlite\ndirectory=/var/lib/rstudio-server\n" > ${DB_CF}
   fi
}
###################################################################
#
# Several key variables needed through the script.
# session is from OOD
# - WORKING_DIR (session_dir)
# - LOG_DIR (WORKING_DIR/logs)
# - TMP_DIR (unique temp directory)

WORKING_DIR="<%= session.staged_root %>"
R_VERSION="<%= context.r_version %>"
LOG_DIR="${WORKING_DIR}/log"  #  local logging output
BIN_DIR="${WORKING_DIR}/bin"    # local bin (for session-specific tasks)
TMP_DIR="${WORKING_DIR}/tmp"    # session-specific /tmp (inside session dir for easy access)
# Username is embedded at job submission time by OOD's ERB renderer,
# so this never depends on SSSD or getent on the compute node.
SCRIPT_USER="<%= ENV["USER"] %>"
JOB_LOG="${LOG_DIR}/job_startup.log"
<%
  # ─── Custom Apptainer Build — process form values at submission time ─────────
  require 'yaml'
  require 'pathname'

  # Sanitize a candidate package name: only allow characters valid in
  # Debian/Ubuntu package names (alphanumeric, hyphens, periods, plus signs).
  # This prevents shell injection from user-supplied input.
  def _sanitize_pkg(name)
    name.to_s.strip.gsub(/[^a-zA-Z0-9\-\.+]/, "")
  end

  # custom_packages may come through as an Array (OOD multi-select) or as a
  # space-separated String depending on OOD version — handle both safely.
  _raw_custom = context.custom_packages rescue ""
  _selected_pkgs = [_raw_custom]
                     .flatten
                     .map(&:to_s)
                     .flat_map { |v| v.split(/\s+/) }
                     .map { |p| _sanitize_pkg(p) }
                     .reject(&:empty?)

  # extra_packages is a free-text field — split on spaces and/or commas.
  _extra_pkgs = context.extra_packages.to_s
                  .split(/[\s,]+/)
                  .map { |p| _sanitize_pkg(p) }
                  .reject(&:empty?)

  # Final deduplicated, sorted package list embedded into the script at submit time.
  _all_packages = (_selected_pkgs + _extra_pkgs).uniq.sort

  # Bypass flag: "1" → skip custom build and use base image directly.
  _bypass_build = context.bypass_custom_build.to_s.strip == "1"

  # Runtime fakeroot flag: "1" → use --fakeroot on apptainer exec.
  _enable_fakeroot_exec = context.enable_fakeroot_exec.to_s.strip == "1"

  # ─── Append new free-text packages to the shared list ────────────────────────
  # This runs server-side at job submission time. Any package in _extra_pkgs
  # that is not already in data/packages.yml is appended so all users see it
  # in the dropdown on their next form load.
  #
  # Uses an exclusive flock for safe concurrent writes. The file is appended
  # as raw YAML text to preserve existing comments and formatting.
  # Failure is non-fatal — a logging issue must not block the user's job.
  if _extra_pkgs.any?
    _shared_pkg_file = Pathname.new(__FILE__).dirname.parent.join('data', 'packages.yml')
    if _shared_pkg_file.exist? && _shared_pkg_file.writable?
      begin
        File.open(_shared_pkg_file.to_s, File::RDWR) do |_f|
          _f.flock(File::LOCK_EX)
          _existing_data  = YAML.safe_load(_f.read) rescue nil
          _existing_pkgs  = (_existing_data.is_a?(Hash) ? (_existing_data['packages'] || []) : [])
                              .flat_map { |p| p['value'].to_s.split }
                              .map(&:strip)
          _new_pkgs = _extra_pkgs.reject { |p| _existing_pkgs.include?(p) }
          if _new_pkgs.any?
            _f.seek(0, IO::SEEK_END)
            _new_pkgs.each do |_pkg|
              # Append a minimal curated entry. Admin can later add a richer
              # label by editing data/packages.yml directly.
              _f.write("  - label: #{_pkg.inspect}\n    value: #{_pkg.inspect}\n")
            end
          end
        end
      rescue
        # Non-fatal: a write failure must not prevent the job from starting.
      end
    end
  end
%>
## RStudio variables: some are session-specific, others are global
## We maintain configuration across jobs in ~/.local/share/rstudio_server
RSTUDIO_SERVER_DIR=${HOME}/.local/share/rstudio_server
RSTUDIO_VAR_LIB=${RSTUDIO_SERVER_DIR}/var/lib
RSTUDIO_OPT_SHARE=${RSTUDIO_SERVER_DIR}/opt/share
RSTUDIO_VAR_RUN=${WORKING_DIR}/var/run
RSTUDIO_ETC=${RSTUDIO_SERVER_DIR}/etc
RSTUDIO_VAR_LOG=${LOG_DIR}
# PAM auth helper used by RStudio
RSTUDIO_AUTH="${BIN_DIR}/auth"
RSTUDIO_RSESSION="${BIN_DIR}/rsession.sh"

# "APPTAINERENV" must preceed anything exported to apptainer environment.
export APPTAINERENV_RSTUDIO_PASSWORD="$password"

case "$R_VERSION" in
    "modified")
        export RSTUDIO_CONTAINER_URI="docker://dockerhub.moffitt.org/ood/rocker-rstudio-modified:latest"
        export ROCKER_CMD="rserver"
        ;;
    "ml")
        export RSTUDIO_CONTAINER_URI="docker://dockerhub.moffitt.org/ood/rocker-multi:latest"
        export ROCKER_CMD="rserver"
        ;;
    "tidyverse")
        export RSTUDIO_CONTAINER_URI="docker://docker.io/rocker/tidyverse:latest"
        export ROCKER_CMD="rserver"
        ;;
    #"shiny-verse")
    #    export RSTUDIO_CONTAINER_URI="docker://docker.io/rocker/shiny-verse:latest"
    #    export ROCKER_CMD="shiny-server"
    #    ;;
    #"r-ver")
    #    export RSTUDIO_CONTAINER_URI="docker://docker.io/rocker/r-ver:latest"
    #    ;;
    #"r-base")
    #    export RSTUDIO_CONTAINER_URI="docker://docker.io/rocker/r-base:latest"
    #    ;;
    "geospatial")
        export RSTUDIO_CONTAINER_URI="docker://docker.io/rocker/geospatial:latest"
        export ROCKER_CMD="rserver"
        ;;
    #"shiny")
    #    export RSTUDIO_CONTAINER_URI="docker://docker.io/rocker/shiny:latest"
    #    export ROCKER_CMD="shiny-server"
    #    ;;
    "rstudio-stable")
        export RSTUDIO_CONTAINER_URI="docker://docker.io/rocker/rstudio-stable:latest"
        export ROCKER_CMD="rserver"
        ;;
    "verse")
        export RSTUDIO_CONTAINER_URI="docker://docker.io/rocker/verse:latest"
        export ROCKER_CMD="rserver"
        ;;
    "binder")
        export RSTUDIO_CONTAINER_URI="docker://docker.io/rocker/binder:latest"
        export ROCKER_CMD="rserver"
        ;;
    "cuda")
        export RSTUDIO_CONTAINER_URI="docker://docker.io/rocker/cuda:latest"
        export ROCKER_CMD="rserver"
        ;;
    "r2u")
        export RSTUDIO_CONTAINER_URI="docker://docker.io/rocker/r2u:latest"
        export ROCKER_CMD="rserver"
        ;;
    "ml-verse")
        export RSTUDIO_CONTAINER_URI="docker://docker.io/rocker/ml-verse:latest"
        export ROCKER_CMD="rserver"
        ;;
    "ropensci")
        export RSTUDIO_CONTAINER_URI="docker://docker.io/rocker/ropensci:latest"
        export ROCKER_CMD="rserver"
        ;;
    "ml-gpu")
        export RSTUDIO_CONTAINER_URI="docker://docker.io/rocker/ml:latest"
        export ROCKER_CMD="rserver"
        ;;
    "dontuse")
        export RSTUDIO_CONTAINER_URI="docker://dockerhub.moffitt.org/ood/rocker-dontuse:latest"
        ;;
    *)
        # Default fallback for standard version numbers (e.g., 4.2.1)
        export RSTUDIO_CONTAINER_URI="docker://dockerhub.moffitt.org/hpc/rocker-rstudio:$R_VERSION"
        ;;
esac

# Initialize environment for execution.
mkdir -p ${LOG_DIR}
echo "`date`: Initializing RStudio environment" >> ${JOB_LOG}
echo "`date`: R Version $R_VERSION" >> ${JOB_LOG}
echo "`date`: Using docker URI $RSTUDIO_CONTAINER_URI" >> ${JOB_LOG}

# setup_env
# Load the required environment. Containers shouldn't need much...
setup_env () {
  source /etc/profile.d/modules.sh
  export MODULEPATH=$MODULEPATH:/app/eb/modules/all:/app/other/modules
  module purge
}
setup_env

####################################################################
#- workspace_init
# A persistant rstudio state is used. The rstudio container defaults to system locations for 
# rstudio server components. Session components are already managed in ~/.local/share/rstudio.
# We create a local ver of this system state and setup bind points to override the system locations.
#
# There are several key directories/files that are needed:
#  - /var/log/rstudio
#  - /etc/rstudio/logging.conf
#  - /etc/rstudio/database.conf
#  - /var/lib/rstudio-server
mkdir -p -m 700 \
	"${RSTUDIO_SERVER_DIR}" \
	"${RSTUDIO_ETC}" \
	"${RSTUDIO_OPT_SHARE}" \
	"${RSTUDIO_VAR_LOG}" \
	"${RSTUDIO_VAR_LIB}" \
	"${RSTUDIO_VAR_RUN}" \
	"${TMP_DIR}"
touch "${RSTUDIO_VAR_RUN}/rstudio-server.pid"
create_log_config "${RSTUDIO_ETC}/logging.conf"
create_db_config "${RSTUDIO_ETC}/database.conf"

####################################################################
#- custom_build
# Optionally build a user-customized Apptainer container with extra Ubuntu
# packages.  Values were sanitized at OOD submit time (ERB stage).
#
# Behaviour:
#   - If bypass_custom_build is checked, skip entirely and use the base image.
#   - If no packages were requested, skip and use the base image.
#   - Otherwise, write (or update) an Apptainer .def file in the user's
#     ~/.local/share/rstudio/custom-build/ directory, then build a .sif.
#   - The build is cached via a hash of (base_image + package_list) stored in
#     a sidecar .hash file — rebuild only when the hash changes.
#   - On build failure the job exits so the user sees a clear error rather
#     than a silent fallback to the base image.

BYPASS_CUSTOM_BUILD="<%= _bypass_build ? "1" : "0" %>"
ALL_PACKAGES="<%= _all_packages.join(" ") %>"
CUSTOM_BUILD_DIR="${HOME}/.local/share/rstudio/custom-build"
CUSTOM_DEF_FILE="${CUSTOM_BUILD_DIR}/rstudio-custom.def"
CUSTOM_SIF_FILE="${CUSTOM_BUILD_DIR}/rstudio-custom.sif"
CUSTOM_HASH_FILE="${CUSTOM_BUILD_DIR}/rstudio-custom.hash"
ENABLE_FAKEROOT_EXEC="<%= _enable_fakeroot_exec ? "1" : "0" %>"

echo "`date`: Custom build bypass flag: ${BYPASS_CUSTOM_BUILD}" >> ${JOB_LOG}
echo "`date`: Requested custom packages: ${ALL_PACKAGES:-none}" >> ${JOB_LOG}
echo "`date`: Runtime fakeroot requested: ${ENABLE_FAKEROOT_EXEC}" >> ${JOB_LOG}

if [[ "${BYPASS_CUSTOM_BUILD}" != "1" && -n "${ALL_PACKAGES}" ]]; then
  # Strip the docker:// scheme prefix to produce the bare image reference
  # used in the Apptainer .def file's "From:" line.
  BASE_IMAGE="${RSTUDIO_CONTAINER_URI#docker://}"

  # Deterministic hash: base image URI + sorted package list.
  # Any change to either component triggers a rebuild.
  CURRENT_HASH=$(printf '%s %s' "${RSTUDIO_CONTAINER_URI}" "${ALL_PACKAGES}" \
                   | md5sum | cut -d' ' -f1)

  NEED_BUILD=1
  if [[ -f "${CUSTOM_SIF_FILE}" && -f "${CUSTOM_HASH_FILE}" ]]; then
    STORED_HASH=$(cat "${CUSTOM_HASH_FILE}" 2>/dev/null || echo "")
    if [[ "${STORED_HASH}" == "${CURRENT_HASH}" ]]; then
      echo "`date`: Custom container cache is valid (hash: ${CURRENT_HASH}) — skipping build" >> ${JOB_LOG}
      NEED_BUILD=0
    else
      echo "`date`: Package list or base image changed — will rebuild" >> ${JOB_LOG}
      echo "`date`:   stored hash : ${STORED_HASH}" >> ${JOB_LOG}
      echo "`date`:   current hash: ${CURRENT_HASH}" >> ${JOB_LOG}
    fi
  else
    echo "`date`: No cached custom container found — building for the first time" >> ${JOB_LOG}
  fi

  if [[ "${NEED_BUILD}" == "1" ]]; then
    mkdir -p -m 700 "${CUSTOM_BUILD_DIR}"

    # Write the Apptainer definition file.  The user can further edit this
    # file at ~/.local/share/rstudio/custom-build/rstudio-custom.def between
    # sessions.  The hash-based cache will detect any manual edits and trigger
    # a rebuild only when the OOD form values change; hand-edits to the .def
    # itself are honoured on the next submit when the form values differ.
    cat > "${CUSTOM_DEF_FILE}" << 'APPTAINER_DEF_SENTINEL'
# Apptainer definition file — generated by the RStudio OOD app.
# Location: ~/.local/share/rstudio/custom-build/rstudio-custom.def
# You may inspect this file or extend the %post section, but note that the
# OOD app regenerates it when the form values change.
APPTAINER_DEF_SENTINEL

    # Append the dynamic portion (variable-expanded, so not single-quoted).
    cat >> "${CUSTOM_DEF_FILE}" << APPTAINER_DEF_EOF
Bootstrap: docker
From: ${BASE_IMAGE}

%post
    apt-get update -qq
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends --fix-missing \
        ${ALL_PACKAGES}
    apt-get clean
    rm -rf /var/lib/apt/lists/*
APPTAINER_DEF_EOF

    chmod 600 "${CUSTOM_DEF_FILE}"
    echo "`date`: Apptainer .def written to: ${CUSTOM_DEF_FILE}" >> ${JOB_LOG}
    echo "`date`: Base image : ${BASE_IMAGE}" >> ${JOB_LOG}
    echo "`date`: Packages   : ${ALL_PACKAGES}" >> ${JOB_LOG}
    echo "`date`: Building custom container — this may take several minutes on first build..." >> ${JOB_LOG}

    # Remove stale artifacts before building.
    rm -f "${CUSTOM_SIF_FILE}" "${CUSTOM_HASH_FILE}"

    echo "Building custom RStudio container (base: ${BASE_IMAGE}, packages: ${ALL_PACKAGES})"
    echo "  This may take 20-60 minutes for large images on the first build."
    echo "  Progress is logged to: ${JOB_LOG}"
    echo "  To check progress: tail -f ${JOB_LOG}"

    if apptainer build --fakeroot --force \
         "${CUSTOM_SIF_FILE}" "${CUSTOM_DEF_FILE}" >> "${JOB_LOG}" 2>&1; then
      printf '%s' "${CURRENT_HASH}" > "${CUSTOM_HASH_FILE}"
      chmod 600 "${CUSTOM_HASH_FILE}"
      echo "`date`: Custom container built successfully: ${CUSTOM_SIF_FILE}" >> ${JOB_LOG}
      echo "Custom container build complete."
    else
      echo "`date`: ERROR: Custom Apptainer build failed." >> ${JOB_LOG}
      echo "ERROR: Custom Apptainer build failed."
      echo "  Definition file : ${CUSTOM_DEF_FILE}"
      echo "  Job log         : ${JOB_LOG}"
      echo "  To recover, re-submit the job with 'Bypass custom container build' checked."
      exit 1
    fi
  fi

  # Switch to the custom image for this session.
  RSTUDIO_CONTAINER_URI="${CUSTOM_SIF_FILE}"
  echo "`date`: Using custom container: ${RSTUDIO_CONTAINER_URI}" >> ${JOB_LOG}

else
  if [[ "${BYPASS_CUSTOM_BUILD}" == "1" ]]; then
    echo "`date`: Custom build bypassed — using base image: ${RSTUDIO_CONTAINER_URI}" >> ${JOB_LOG}
  else
    echo "`date`: No custom packages requested — using base image: ${RSTUDIO_CONTAINER_URI}" >> ${JOB_LOG}
  fi
fi

# Validate runtime fakeroot prerequisites and set apptainer exec flag.
APPTAINER_FAKEROOT_FLAG=""
if [[ "${ENABLE_FAKEROOT_EXEC}" == "1" ]]; then
  FAKEROOT_CHECK_FAILED=0

  if ! command -v newuidmap >/dev/null 2>&1 || ! command -v newgidmap >/dev/null 2>&1; then
    echo "`date`: ERROR: fakeroot runtime requested but newuidmap/newgidmap are not available on this node." >> ${JOB_LOG}
    FAKEROOT_CHECK_FAILED=1
  fi

  if ! grep -q "^${USER}:" /etc/subuid 2>/dev/null; then
    echo "`date`: ERROR: fakeroot runtime requested but /etc/subuid has no entry for user ${USER}." >> ${JOB_LOG}
    FAKEROOT_CHECK_FAILED=1
  fi

  if ! grep -q "^${USER}:" /etc/subgid 2>/dev/null; then
    echo "`date`: ERROR: fakeroot runtime requested but /etc/subgid has no entry for user ${USER}." >> ${JOB_LOG}
    FAKEROOT_CHECK_FAILED=1
  fi

  if [[ "${FAKEROOT_CHECK_FAILED}" == "1" ]]; then
    echo "ERROR: fakeroot runtime prerequisites are not met for user ${USER}." >&2
    echo "  Required: newuidmap/newgidmap and matching /etc/subuid + /etc/subgid entries." >&2
    echo "  See ${JOB_LOG} for details." >&2
    exit 1
  fi

  APPTAINER_FAKEROOT_FLAG="--fakeroot"
  echo "`date`: Runtime fakeroot enabled for apptainer exec." >> ${JOB_LOG}
else
  echo "`date`: Runtime fakeroot disabled for apptainer exec." >> ${JOB_LOG}
fi

# Write rserver.conf so auth settings are applied regardless of RStudio Server version.
# Newer Rocker-based images may ignore --auth-encrypt-password 0 as a CLI flag;
# a config file is honored by all versions.
RSTUDIO_RSERVER_CONF="${RSTUDIO_ETC}/rserver.conf"
(
umask 077
cat > "${RSTUDIO_RSERVER_CONF}" << EOF
auth-pam-helper-path=${RSTUDIO_AUTH}
auth-encrypt-password=0
EOF
)

# set_variables
# There are a number of environment variables to setup for execution.
# - apptainer variables
# - rstudio variables

########################################
# apptainer variables
# https://apptainer.org/docs/user/main/cli/apptainer_exec.html

# HPC users are resolved via LDAP/SSSD and are not present in the host's
# flat /etc/passwd. Use 'getent' (which queries LDAP/SSSD on the host) to
# extract just the current user's entry into a synthetic passwd/group file,
# then bind-mount those into the container. This makes the user visible to
# rserver without requiring LDAP access inside the container.
<%
  require 'etc'
  _pw  = Etc.getpwnam(ENV["USER"])
  _grp = Etc.getgrgid(_pw.gid)
  _erb_passwd = "#{_pw.name}:x:#{_pw.uid}:#{_pw.gid}:#{_pw.gecos}:#{_pw.dir}:#{_pw.shell}"
  _erb_group  = "#{_grp.name}:x:#{_grp.gid}:"
%>
# Locate the host CA bundle so HTTPS inside the container trusts the HPC
# corporate SSL CA. Rocker images ship their own CA bundle which does not
# include any site-specific intermediate CAs.
CA_BUNDLE=""
for f in \
    /etc/pki/ca-trust/extracted/pem/tls-ca-bundle.pem \
    /etc/pki/tls/certs/ca-bundle.crt \
    /etc/ssl/certs/ca-certificates.crt \
    /etc/ssl/ca-bundle.pem; do
  if [[ -f "$f" ]]; then
    CA_BUNDLE="$f"
    break
  fi
done
echo "`date`: Host CA bundle: ${CA_BUNDLE:-not found}" >> ${JOB_LOG}

# passwd/group entries are embedded at submission time by OOD's ERB renderer
# (which runs on the OOD server where SSSD is reliable). No getent or id calls
# are made on the compute node.
CONTAINER_PASSWD="${TMP_DIR}/passwd"
CONTAINER_GROUP="${TMP_DIR}/group"
cat > "${CONTAINER_PASSWD}" << 'OOD_PASSWD_EOF'
<%= _erb_passwd %>
OOD_PASSWD_EOF
cat > "${CONTAINER_GROUP}" << 'OOD_GROUP_EOF'
<%= _erb_group %>
OOD_GROUP_EOF
echo "`date`: Container passwd entry: $(cat "${CONTAINER_PASSWD}")" >> ${JOB_LOG}

# Bind RSTUDIO_ETC as a directory (not individual files).
# Apptainer cannot bind-mount a file to a target path that does not already
# exist inside the container. Stock Rocker images do not ship an
# /etc/rstudio/rserver.conf, so a file-level bind silently fails.
# Binding the whole directory works unconditionally.
BIND_POINTS=""\
"${CONTAINER_PASSWD}:/etc/passwd:ro,"\
"${CONTAINER_GROUP}:/etc/group:ro,"\
"${RSTUDIO_ETC}:/etc/rstudio,"\
"${RSTUDIO_VAR_LOG}:/var/log/rstudio,"\
"${RSTUDIO_VAR_LIB}:/var/lib/rstudio-server,"\
"${RSTUDIO_VAR_RUN}:/run/rstudio-server,"\
"${RSTUDIO_OPT_SHARE}:/opt/share,"\
"${BIN_DIR}/shiny-server.conf:/etc/shiny-server/shiny-server.conf,"\
"${TMP_DIR}:/tmp"

# Add CA bundle bind if one was found on the host
if [[ -n "${CA_BUNDLE}" ]]; then
  BIND_POINTS="${BIND_POINTS},${CA_BUNDLE}:${CA_BUNDLE}:ro"
fi

echo "`date`: rserver.conf contents:" >> ${JOB_LOG}
cat "${RSTUDIO_RSERVER_CONF}" >> ${JOB_LOG}

echo "`date`: Bind points for container:" >> ${JOB_LOG}
echo "$BIND_POINTS" | tr ',' '\n' >> ${JOB_LOG}

# rsession
########################################
# rstudio variables
# See https://docs.posit.co/ide/server-pro/reference/rserver_conf.html

# Containerized rserver starts with user space environment defined on host, but 
# the spawned rsession from rserver starts on limited environment, only related 
# to R = no SLURM*, http*, ...so anything passed to rsession needs to be set in 
# $RSTUDIO_RESSION wrapper script.
(
umask 077
sed 's/^ \{2\}//' > "${RSTUDIO_RSESSION}" << EOL
#!/usr/bin/env bash

# Log all output from this script
export RSESSION_LOG_FILE="${LOG_DIR}/rsession.log"

exec &>>"\${RSESSION_LOG_FILE}"
set -x

# Per existing scripts, some explicit envvars set here.
export TZ="US/Eastern"
export HOME="$HOME"
export R_LIBS_SITE="$R_LIBS_SITE"

# Point curl and OpenSSL inside the container at the host CA bundle so
# that HTTPS requests from R/RStudio trust the HPC corporate SSL CA.
# Without this, RStudio's Posit AI manifest fetch (and any user HTTPS
# calls) fail with an SSL certificate error.
export CURL_CA_BUNDLE="${CA_BUNDLE}"
export SSL_CERT_FILE="${CA_BUNDLE}"

# Prevent OpenMP-enhanced libraries from spawning more threads 
export OMP_NUM_THREADS=${SLURM_JOB_CPUS_PER_NODE}

# Launch the original command
echo "Launching rsession..."
exec /usr/lib/rstudio-server/bin/rsession "\${@}"
EOL
)
chmod 700 "${RSTUDIO_RSESSION}"

###########################
# Launch the RStudio Server

# Set working directory to home directory
cd "${HOME}"

# Output debug info
printf "`date`: Module list\n\t" >> ${JOB_LOG}
module list 2>> ${JOB_LOG}
echo "`date`: Executing rstudio server on `hostname`." >> ${JOB_LOG}

## fix rstudio active session error on start
current_state_files=$(echo ~/.local/share/rstudio/sessions/active/*/session-persistent-state)
for f in $current_state_files; do
  if [ -f "$f" ]; then
    echo "`date`: Fixing potential rstudio session failure error states in $f" >> ${JOB_LOG}
    sed -i -e 's/abend="[1-2]"/abend="0"/' $f
  else
    echo "$f doesn't exists. Continuing..." >> ${JOB_LOG}
  fi
done

sed -i -e "s/:current_user:/$USER/" $BIN_DIR/shiny-server.conf
sed -i -e "s/3838/$port/" $BIN_DIR/shiny-server.conf

# Write password to a file inside the container's /tmp (TMP_DIR is bound to /tmp).
# Newer RStudio Server versions (used in stock Rocker containers) do NOT inherit
# RSTUDIO_PASSWORD in the PAM helper subprocess, so an env var alone is unreliable.
mkdir -p "${TMP_DIR}/rstudio-server"
(umask 077; printf '%s' "${password}" > "${TMP_DIR}/rstudio-server/rstudio-passwd")
# Write the expected username so bin/auth can validate it without relying on
# $USER inside the container (Rocker sets $USER=jovyan, not the HPC username).
(umask 077; printf '%s' "${SCRIPT_USER}" > "${TMP_DIR}/rstudio-server/rstudio-user")
echo "`date`: Password file written to ${TMP_DIR}/rstudio-server/rstudio-passwd" >> ${JOB_LOG}
echo "`date`: Username file written to ${TMP_DIR}/rstudio-server/rstudio-user (${SCRIPT_USER})" >> ${JOB_LOG}

set -x
echo "`date`: Starting up rserver..." >> ${JOB_LOG}

# Container startup
apptainer exec \
  ${APPTAINER_FAKEROOT_FLAG} \
	--nv \
	-B "${BIND_POINTS}" \
	"$RSTUDIO_CONTAINER_URI" \
	$ROCKER_CMD \
		--www-port "${port}" \
		--auth-none 0 \
		--rsession-path "${RSTUDIO_RSESSION}" \
		--server-app-armor-enabled=0 \
		--server-data-dir /tmp \
		--secure-cookie-key-file /tmp/rstudio-server/secure-cookie-key \
		--database-config-file "${DB_CF}" \
		--server-user "${SCRIPT_USER}"
