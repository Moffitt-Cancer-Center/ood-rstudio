#!/usr/bin/env bash

# Confirm username is supplied
if [[ $# -lt 1 ]]; then
  echo "Usage: auth USERNAME"
  exit 1
fi
USERNAME="${1}"

# Read password from file first (reliable across all RStudio Server versions).
# TMP_DIR is bind-mounted to /tmp in the container, so the file written by
# script.sh.erb at TMP_DIR/rstudio-server/rstudio-passwd is accessible here
# at /tmp/rstudio-server/rstudio-passwd.
# Fall back to the RSTUDIO_PASSWORD env var for backwards compatibility.
RSTUDIO_PASSWD_FILE="${RSTUDIO_PASSWORD_FILE:-/tmp/rstudio-server/rstudio-passwd}"
if [[ -f "${RSTUDIO_PASSWD_FILE}" ]]; then
  RSTUDIO_PASSWORD="$(cat "${RSTUDIO_PASSWD_FILE}")"
fi

# Confirm a password was resolved
if [[ -z "${RSTUDIO_PASSWORD}" ]]; then
  echo "Cannot authenticate: password file not found at ${RSTUDIO_PASSWD_FILE} and RSTUDIO_PASSWORD env var is not set"
  exit 1
fi

# Read in the password from user
read -s -p "Password: " PASSWORD
echo ""

# Debug log (written inside container → host TMP_DIR via /tmp bind)
AUTH_LOG="/tmp/rstudio-server/auth-debug.log"
mkdir -p "$(dirname "${AUTH_LOG}")" 2>/dev/null
{
  echo "$(date): auth called"
  echo "  USERNAME arg : ${USERNAME}"
  echo "  USER env     : ${USER}"
  echo "  passwd file  : ${RSTUDIO_PASSWD_FILE}"
  echo "  file exists  : $(test -f "${RSTUDIO_PASSWD_FILE}" && echo YES || echo NO)"
  echo "  stored pw len: ${#RSTUDIO_PASSWORD}"
  echo "  input  pw len: ${#PASSWORD}"
} >> "${AUTH_LOG}" 2>/dev/null

if [[ "${USERNAME}" == "${USER}" && "${PASSWORD}" == "${RSTUDIO_PASSWORD}" ]]; then
  echo "$(date): auth SUCCESS for ${USERNAME}" >> "${AUTH_LOG}" 2>/dev/null
  echo "Successful authentication"
  exit 0
else
  echo "$(date): auth FAILURE for ${USERNAME} (user_match=$(test "${USERNAME}" = "${USER}" && echo Y || echo N) pw_match=$(test "${PASSWORD}" = "${RSTUDIO_PASSWORD}" && echo Y || echo N))" >> "${AUTH_LOG}" 2>/dev/null
  echo "Invalid authentication"
  exit 1
fi
